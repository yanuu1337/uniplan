// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClassGroup {
  id                      String                   @id
  name                    String
  description             String?
  password                String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  members                 UserClassGroup[]
  recurringEventTemplates RecurringEventTemplate[]
  events                  Event[]
  createdById             String
  createdBy               User                     @relation(fields: [createdById], references: [id], name: "classGroupCreatedBy")

  @@map("class_group")
}

model RecurringEventTemplate {
  id           String     @id @default(cuid())
  name         String
  description  String?
  weekday      Int? // 0-6 (Sunday-Saturday), null for one-time events
  startTime    DateTime // Time component only (HH:MM)
  endTime      DateTime // Time component only (HH:MM)
  startDate    DateTime // First occurrence date
  endDate      DateTime? // Last occurrence date (null = infinite)
  classGroupId String
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id])

  occurrences Event[] // Generated occurrences

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurring_event_template")
}

model Event {
  id            String      @id @default(cuid())
  name          String
  description   String?
  startDateTime DateTime
  endDateTime   DateTime
  status        EventStatus @default(SCHEDULED)

  // Link to template if this is part of a recurring series
  templateId String?
  template   RecurringEventTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Override fields (if different from template)
  // If null, use template values
  overrideName        String?
  overrideDescription String?
  overrideStartTime   DateTime?
  overrideEndTime     DateTime?

  classGroupId String
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDateTime])
  @@index([classGroupId])
  @@index([templateId])
  @@map("event")
}

enum EventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  MODIFIED
}

enum ClassGroupRole {
  OWNER
  MEMBER
}

// Junction table for User-ClassGroup relationship with role and preferences
model UserClassGroup {
  id           String         @id @default(cuid())
  userId       String
  classGroupId String
  role         ClassGroupRole @default(MEMBER)

  // Display preferences
  isVisible Boolean @default(true) // Whether to show this group's events on calendar
  color     String? // Optional color for calendar display (hex code)

  // Notification preferences (optional, for future use)
  notifyBeforeMinutes Int? // Notify X minutes before events (null = no notifications)

  // Timestamps
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)

  @@unique([userId, classGroupId])
  @@index([userId])
  @@index([classGroupId])
  @@map("user_class_group")
}

// Better-Auth Authentication Models

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]

  classGroupMemberships UserClassGroup[]
  createdClassGroups    ClassGroup[]     @relation(name: "classGroupCreatedBy")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}
